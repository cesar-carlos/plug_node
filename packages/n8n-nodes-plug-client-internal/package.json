{
  "name": "n8n-nodes-plug-client-internal",
  "version": "0.1.0",
  "description": "Internal Plug Client n8n nodes with REST and Socket relay support",
  "license": "MIT",
  "author": {
    "name": "Plug Node Team"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cesar-carlos/plug_node.git",
    "directory": "packages/n8n-nodes-plug-client-internal"
  },
  "bugs": {
    "url": "https://github.com/cesar-carlos/plug_node/issues"
  },
  "homepage": "https://github.com/cesar-carlos/plug_node/tree/main/packages/n8n-nodes-plug-client-internal#readme",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "plug",
    "socket.io",
    "relay"
  ],
  "scripts": {
    "sync-shared": "node ../../scripts/sync-shared.mjs --package n8n-nodes-plug-client-internal",
    "prebuild": "npm run sync-shared",
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "predev": "npm run sync-shared",
    "dev": "n8n-node dev",
    "prelint": "npm run sync-shared",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "pretest": "npm run sync-shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --pretty false --noEmit",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/PlugClientApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PlugClient/PlugClient.node.js"
    ]
  },
  "dependencies": {
    "socket.io-client": "4.8.3"
  },
  "devDependencies": {
    "@n8n/node-cli": "0.28.0",
    "@types/node": "25.6.0",
    "eslint": "9.39.4",
    "n8n-workflow": "2.16.0",
    "prettier": "3.8.3",
    "release-it": "20.0.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
