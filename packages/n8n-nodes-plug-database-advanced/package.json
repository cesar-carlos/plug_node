{
  "name": "n8n-nodes-plug-database-advanced",
  "version": "1.3.0",
  "description": "Plug Database n8n nodes with REST and consumer socket support",
  "license": "MIT",
  "author": {
    "name": "cesar-carlos"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cesar-carlos/plug_node.git",
    "directory": "packages/n8n-nodes-plug-database-advanced"
  },
  "bugs": {
    "url": "https://github.com/cesar-carlos/plug_node/issues"
  },
  "homepage": "https://github.com/cesar-carlos/plug_node/tree/main/packages/n8n-nodes-plug-database-advanced#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "plug",
    "database",
    "socket.io",
    "relay",
    "consumer-socket"
  ],
  "scripts": {
    "sync-shared": "node ../../scripts/sync-shared.mjs --package n8n-nodes-plug-database-advanced",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('../../.tsbuildinfo/n8n-nodes-plug-database-advanced.tsbuildinfo', { force: true });\"",
    "prebuild": "npm run clean && npm run sync-shared",
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "predev": "npm run sync-shared",
    "dev": "n8n-node dev",
    "prelint": "npm run sync-shared",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "pretest": "npm run sync-shared",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "npm run sync-shared",
    "typecheck": "tsc --pretty false --noEmit",
    "release": "n8n-node release",
    "prepublishOnly": "npm run clean && npm run sync-shared && npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/PlugDatabaseAdvancedApi.credentials.js",
      "dist/credentials/PlugDatabaseAdvancedClientApi.credentials.js",
      "dist/credentials/PlugDatabaseAdvancedUserApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PlugDatabaseAdvanced/PlugDatabaseAdvanced.node.js",
      "dist/nodes/PlugDatabaseAdvancedPdf/PlugDatabaseAdvancedPdf.node.js",
      "dist/nodes/PlugDatabaseAdvancedBarcode/PlugDatabaseAdvancedBarcode.node.js",
      "dist/nodes/PlugDatabaseAdvancedSocketEvent/PlugDatabaseAdvancedSocketEvent.node.js",
      "dist/nodes/PlugDatabaseAdvancedSocketEventTrigger/PlugDatabaseAdvancedSocketEventTrigger.node.js",
      "dist/nodes/PlugDatabaseAdvancedClientAccess/PlugDatabaseAdvancedClientAccess.node.js",
      "dist/nodes/PlugDatabaseAdvancedUserAccess/PlugDatabaseAdvancedUserAccess.node.js"
    ]
  },
  "dependencies": {
    "@bwip-js/node": "4.10.1",
    "@zxing/library": "^0.21.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.3",
    "jsonata": "^2.1.0",
    "marked": "^18.0.3",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "playwright-core": "1.59.1",
    "sharp": "^0.34.5",
    "socket.io-client": "4.8.3",
    "to-words": "^5.5.0"
  },
  "devDependencies": {
    "@n8n/node-cli": "0.28.0",
    "@types/node": "25.6.0",
    "eslint": "9.39.4",
    "n8n-workflow": "2.16.0",
    "prettier": "3.8.3",
    "release-it": "20.0.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
