PLUG_E2E_USER=your_user@example.com
PLUG_E2E_PASSWORD=your_password
PLUG_E2E_AGENT_ID=00000000-0000-0000-0000-000000000000
PLUG_E2E_CLIENT_TOKEN=your_client_token
PLUG_E2E_SOCKET_AGENT_ID=
PLUG_E2E_SOCKET_CLIENT_TOKEN=
PLUG_E2E_BASE_URL=https://plug-server.se7esistemassinop.com.br/api/v1
PLUG_E2E_TIMEOUT_MS=30000
PLUG_E2E_SQL_QUERY_CLIENTE=SELECT TOP 10 * FROM Cliente
PLUG_E2E_SQL_QUERY_VENDEDOR=SELECT TOP 10 * FROM Vendedor
PLUG_E2E_SQL_QUERY_PRODUTO=SELECT TOP 10 * FROM Produto
PLUG_E2E_SQL_QUERY_EMPTY=SELECT * FROM Cliente WHERE CodCliente=1
PLUG_E2E_DENIED_RESOURCE=
PLUG_E2E_SQL_QUERY_MULTI_RESULT_SUCCESS=SELECT TOP 5 * FROM Cliente; SELECT TOP 5 * FROM Vendedor
PLUG_E2E_SQL_QUERY_MULTI_RESULT_MIXED=
PLUG_E2E_SQL_QUERY_UNAUTHORIZED=
PLUG_E2E_SQL_QUERY_INVALID=SELECT FROM Cliente
PLUG_E2E_BATCH_COMMANDS_JSON=[{"sql":"SELECT TOP 1 * FROM Cliente"},{"sql":"SELECT TOP 1 * FROM Vendedor"}]
PLUG_E2E_SQL_HUB_OPTIONS_QUERY=SELECT TOP 100 * FROM Cliente ORDER BY CodCliente
# PLUG_E2E_CANCEL_EXECUTION_ID=
# PLUG_E2E_CANCEL_REQUEST_ID=
# Optional legacy overrides (used when Vendedor/Produto vars are empty):
# PLUG_E2E_SQL_QUERY_MARCA=
# PLUG_E2E_SQL_QUERY_GRUPO_PRODUTO=
# Optional mutating bulk insert E2E (safe staging table only):
# PLUG_E2E_BULK_INSERT_JSON={"table":"dbo.example","columns":[{"name":"id","type":"i64"}],"rows":[[1]]}
# Optional hub stress probe (not part of npm run verify; off by default):
# PLUG_E2E_STRESS_ENABLED=1
# PLUG_E2E_STRESS_CONCURRENCY=4
# PLUG_E2E_STRESS_REQUEST_COUNT=12
# PLUG_E2E_STRESS_MIN_SUCCESS_RATIO=0.25
# PLUG_E2E_STRESS_CHANNELS=rest,socket
